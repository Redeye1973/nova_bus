; Godot 4.6 — isometric shmup stub; meshes from Asset Library #2124 (KayKit Space Base Bits).
config_version=5

[application]
config/name="assetlib_iso_shmup"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[display]
window/size/viewport_width=1280
window/size/viewport_height=720
